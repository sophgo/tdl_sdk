{
  "server_port": 8000,
  "data_path": "./capture_result",
  "model_dir": "./models",
  "txt_dir": "./txt_dir",

  "frame_buffer_size": 1,
  "pipelines": [
    {
      "name": "clip_033",
      "nodes": {
        "video_node": {
          "video_type": "image_folder",
          "video_path": "./image",
          "is_loop": false
        },
        "object_detection_node": {
          "config_thresh": 0.5
        },
        "track_node": {
          "fuse_track": true
        },
        "snapshot_node": {
          "snapshot_interval": 5,
          "min_snapshot_size": 40,
          "crop_size_min": 128,
          "crop_size_max": 256,
          "snapshot_quality_threshold": 0,
          "crop_square": true,
          "capture_person": true,

          "encoder_mode": 0,
          "vechn": 1,
          "jpg_quality": 30
        },

        "clip_image_feature_node": {
        },
        "resize_image_node": {
          "resize_width": 960,
          "resize_height": 540
        }

      }
    }
  ]

}
